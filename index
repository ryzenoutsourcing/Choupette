  let VEHICLES = [
    { id: 1, name: "Audi RS6 Avant", year: 2023, price: "€ 129.900", priceNum: 129900, km: 18200, fuel: "Benzine", transmission: "Automaat", hp: 600, inkoop: 105000, onkosten: 3200, verkoop: 129900, hist: "Full dealer onderhouden, 1e eigenaar", photoCount: 16, status: "available", technischeFiche: "113-punten mastercheck, originele staat, geen schade verleden", extraNotitie: "Gratis inruil van uw huidige auto" },
    { id: 2, name: "BMW i4 M50", year: 2024, price: "€ 64.500", priceNum: 64500, km: 19000, fuel: "Elektrisch", transmission: "Automaat", hp: 544, inkoop: 52000, onkosten: 2100, verkoop: 64500, hist: "Import uit Duitsland, accu garantie", photoCount: 14, status: "available", technischeFiche: "Accu check uitgevoerd, laadpaal klaar", extraNotitie: "Inclusief thuislader" },
    { id: 3, name: "Porsche Taycan 4S", year: 2023, price: "€ 112.000", priceNum: 112000, km: 12400, fuel: "Elektrisch", transmission: "Automaat", hp: 530, inkoop: 94000, onkosten: 4500, verkoop: 112000, hist: "Performance plus pakket", photoCount: 18, status: "available", technischeFiche: "Porsche Approved garantie", extraNotitie: "Sportdesign pakket" },
    { id: 4, name: "Mercedes-AMG GLE 450", year: 2022, price: "€ 89.900", priceNum: 89900, km: 33000, fuel: "Benzine", transmission: "9G-Tronic", hp: 367, inkoop: 74000, onkosten: 3800, verkoop: 89900, hist: "Nederlands dossier", photoCount: 15, status: "available", technischeFiche: "AMG line, volledige historie", extraNotitie: "Originele dealeronderhouden" }
  ];
  
  for (let i = 5; i <= 25; i++) {
    VEHICLES.push({
      id: i, name: `Demo Auto ${i}`, year: 2020 + (i % 5), price: `€ ${35000 + (i * 2000)}`, priceNum: 35000 + (i * 2000),
      km: 10000 + (i * 3000), fuel: i % 2 === 0 ? "Benzine" : "Diesel", transmission: "Automaat", hp: 200 + i,
      inkoop: 30000 + (i * 1500), onkosten: 1500, verkoop: 35000 + (i * 2000),
      hist: `Demo historie voor voertuig ${i}`, photoCount: 10, status: "available",
      technischeFiche: `Technische fiche voor demo auto ${i}`, extraNotitie: `Extra notitie voor demo auto ${i}`
    });
  }
  
  let SALES_RECORDS = [];
  let nextVehicleId = 26;
  let AppState = { userRole: 'guest', activeVehicle: null, currentPhotoIndex: 0, currentPhotos: [] };
  let activeSoldVehicle = null;
  let uploadedPhotos = [];
  let currentPage = 1;
  let totalPages = 1;
  let adminCurrentPage = 1;
  let adminTotalPages = 1;
  let selectedVehicleIds = new Set();
  
  const Utils = {
    generatePhotos(vehicleId, count) {
      let photos = [];
      for (let i = 1; i <= count; i++) {
        photos.push(`${CONFIG.placeholderImages}${vehicleId}+Choupette+${i}`);
      }
      return photos;
    },
    formatCurrency(amount) { return '€ ' + amount.toLocaleString(); },
    formatKm(km) { return km.toLocaleString() + ' km'; }
  };
  
  function generateWhatsAppText(vehicle) {
    return encodeURIComponent(
      `🚗 *${vehicle.name}* (${vehicle.year})\n` +
      `💰 Prijs: ${vehicle.price}\n` +
      `📍 Kilometerstand: ${(vehicle.km || 0).toLocaleString()} km\n` +
      `⛽ Brandstof: ${vehicle.fuel}\n` +
      `🔧 Transmissie: ${vehicle.transmission}\n` +
      `📋 Technische fiche: ${vehicle.technischeFiche || "113-punten mastercheck"}\n` +
      `📝 Extra: ${vehicle.extraNotitie || "Geen extra notitie"}\n` +
      `🔗 Bekijk voertuig: ${window.location.href}`
    );
  }
  
  // ============================================================
  // SIDE SLIDE FUNCTIES
  // ============================================================
  const SideSlide = {
    elements: {
      container: document.getElementById('sideSlide'),
      overlay: document.getElementById('slideOverlay'),
      openBtn: document.getElementById('openCertifiedSlide'),
      closeBtn: document.getElementById('closeSlideBtn'),
      vehicleList: document.getElementById('vehicleListSlide'),
      prevBtn: document.getElementById('prevPageBtn'),
      nextBtn: document.getElementById('nextPageBtn'),
      pageInfo: document.getElementById('pageInfo')
    },
    
    getAvailableVehicles() { return VEHICLES.filter(v => v.status === 'available'); },
    
    updatePaginationButtons() {
      if (this.elements.prevBtn) this.elements.prevBtn.disabled = currentPage <= 1;
      if (this.elements.nextBtn) this.elements.nextBtn.disabled = currentPage >= totalPages;
      if (this.elements.pageInfo) this.elements.pageInfo.innerText = `Pagina ${currentPage} van ${totalPages}`;
    },
    
    renderVehicleList() {
      if (!this.elements.vehicleList) return;
      const availableVehicles = this.getAvailableVehicles();
      totalPages = Math.ceil(availableVehicles.length / CONFIG.vehiclesPerPage);
      if (currentPage > totalPages) currentPage = totalPages;
      if (currentPage < 1) currentPage = 1;
      if (totalPages === 0) totalPages = 1;
      
      const startIndex = (currentPage - 1) * CONFIG.vehiclesPerPage;
      const vehiclesToShow = availableVehicles.slice(startIndex, startIndex + CONFIG.vehiclesPerPage);
      
      this.elements.vehicleList.innerHTML = '';
      if (vehiclesToShow.length === 0) {
        this.elements.vehicleList.innerHTML = '<div style="text-align:center; padding:2rem;">Geen voertuigen beschikbaar</div>';
      } else {
        vehiclesToShow.forEach(vehicle => {
          const card = document.createElement('div');
          card.className = 'vehicle-slide-card';
          card.innerHTML = `<div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap;"><div><strong style="font-size:1.2rem;">${vehicle.name} (${vehicle.year})</strong><div style="color: var(--vibrant-blue); font-weight: 700;">${vehicle.price}</div><div style="font-size:0.8rem;">${Utils.formatKm(vehicle.km)} · ${vehicle.fuel}</div></div><button class="detail-dropdown-btn" data-id="${vehicle.id}">Deep-Dive Details →</button></div>`;
          this.elements.vehicleList.appendChild(card);
        });
      }
      this.updatePaginationButtons();
      document.querySelectorAll('.detail-dropdown-btn').forEach(btn => {
        btn.addEventListener('click', (e) => { Modal.open(parseInt(btn.dataset.id)); });
      });
    },
    
    nextPage() { if (currentPage < totalPages) { currentPage++; this.renderVehicleList(); } },
    prevPage() { if (currentPage > 1) { currentPage--; this.renderVehicleList(); } },
    resetPagination() { currentPage = 1; this.renderVehicleList(); },
    
    open() {
      this.elements.container.classList.add('open');
      this.elements.overlay.classList.add('active');
      document.body.style.overflow = 'hidden';
      this.resetPagination();
    },
    
    close() {
      this.elements.container.classList.remove('open');
      this.elements.overlay.classList.remove('active');
      document.body.style.overflow = '';
    },
    
    init() {
      if (this.elements.openBtn) this.elements.openBtn.addEventListener('click', (e) => { e.preventDefault(); this.open(); });
      if (this.elements.closeBtn) this.elements.closeBtn.addEventListener('click', () => this.close());
      if (this.elements.overlay) this.elements.overlay.addEventListener('click', () => this.close());
      if (this.elements.prevBtn) this.elements.prevBtn.addEventListener('click', () => this.prevPage());
      if (this.elements.nextBtn) this.elements.nextBtn.addEventListener('click', () => this.nextPage());
    }
  };
  
  // ============================================================
  // MODAL FUNCTIES
  // ============================================================
  const Modal = {
    elements: {
      modal: document.getElementById('vehicleModal'),
      closeBtn: document.getElementById('closeModalBtn'),
      contactBtn: document.getElementById('contactSellerBtn'),
      dynamicContent: document.getElementById('modalDynamicContent')
    },
    
    open(vehicleId) {
      const vehicle = VEHICLES.find(v => v.id === vehicleId);
      if (!vehicle) return;
      AppState.activeVehicle = vehicle;
      AppState.currentPhotos = Utils.generatePhotos(vehicle.id, vehicle.photoCount);
      AppState.currentPhotoIndex = 0;
      this.render();
      this.elements.modal.classList.add('active');
      document.body.style.overflow = 'hidden';
    },
    
    close() {
      this.elements.modal.classList.remove('active');
      document.body.style.overflow = '';
    },
    
    scrollToContactForm() {
      this.close();
      const contactSection = document.getElementById('contact-form');
      if (contactSection) {
        contactSection.scrollIntoView({ behavior: 'smooth' });
      }
    },
    
    render() {
      if (!this.elements.dynamicContent || !AppState.activeVehicle) return;
      const vehicle = AppState.activeVehicle;
      const winst = vehicle.verkoop - (vehicle.inkoop + vehicle.onkosten);
      const isAdmin = AppState.userRole === 'admin';
      const financeHTML = isAdmin ? `<div class="admin-finance-card visible"><h4>💰 Financiële data (Admin only)</h4><p><strong>Inkoopprijs:</strong> ${Utils.formatCurrency(vehicle.inkoop)}</p><p><strong>Onkosten:</strong> ${Utils.formatCurrency(vehicle.onkosten)}</p><p><strong>Verkoopprijs:</strong> ${Utils.formatCurrency(vehicle.verkoop)}</p><p><strong>Bruto Winst:</strong> ${Utils.formatCurrency(winst)}</p></div>` : `<div class="admin-finance-card"></div>`;
      const technischeFicheTekst = vehicle.technischeFiche || "113-punten mastercheck, originele staat, geen schade verleden";
      const extraNotitieTekst = vehicle.extraNotitie || "";
      
      this.elements.dynamicContent.innerHTML = `
        <div class="gallery-container">
          <div class="main-image-wrapper">
            <button class="gallery-nav prev" id="galleryPrevBtn"><i class="fas fa-chevron-left"></i></button>
            <img class="main-image" id="mainGalleryImg" src="${AppState.currentPhotos[0]}" alt="${vehicle.name}">
            <button class="gallery-nav next" id="galleryNextBtn"><i class="fas fa-chevron-right"></i></button>
          </div>
          <div class="thumbnail-strip" id="thumbnailStrip"></div>
        </div>
        <div class="car-detail-info">
          <h2 style="font-size: 2rem;">${vehicle.name}</h2>
          <div style="display: flex; gap: 2rem; flex-wrap: wrap; margin: 1rem 0;">
            <span><i class="fas fa-calendar"></i> ${vehicle.year}</span>
            <span><i class="fas fa-tachometer-alt"></i> ${Utils.formatKm(vehicle.km)}</span>
            <span><i class="fas fa-gas-pump"></i> ${vehicle.fuel}</span>
            <span><i class="fas fa-cogs"></i> ${vehicle.transmission}</span>
            <span><i class="fas fa-horse-head"></i> ${vehicle.hp} pk</span>
          </div>
          <div class="vehicle-price" style="font-size: 2rem; color: var(--vibrant-blue);">${vehicle.price}</div>
          <div style="margin: 1rem 0;"><span style="background:#0046ff10; padding:4px 12px; border-radius: 50px;">✓ Master Diagnose OK</span> <span style="background:#10b98110; padding:4px 12px; border-radius: 50px;">✓ Keuringsgarantie</span></div>
          <p><strong>Historisch dossier:</strong> ${vehicle.hist}</p>
          <p><strong>📋 Technische fiche:</strong> ${technischeFicheTekst}</p>
          ${extraNotitieTekst ? `<p><strong>📝 Extra notitie:</strong> ${extraNotitieTekst}</p>` : ''}
          ${financeHTML}
        </div>
      `;
      this.setupGallery();
    },
    
    setupGallery() {
      const thumbStrip = document.getElementById('thumbnailStrip');
      if (!thumbStrip) return;
      thumbStrip.innerHTML = '';
      AppState.currentPhotos.forEach((photo, idx) => {
        const thumb = document.createElement('img');
        thumb.src = photo;
        thumb.classList.add('thumbnail');
        if (idx === AppState.currentPhotoIndex) thumb.classList.add('active-thumb');
        thumb.addEventListener('click', () => this.setActivePhoto(idx));
        thumbStrip.appendChild(thumb);
      });
      const mainImg = document.getElementById('mainGalleryImg');
      document.getElementById('galleryPrevBtn')?.addEventListener('click', () => this.navigateGallery(-1));
      document.getElementById('galleryNextBtn')?.addEventListener('click', () => this.navigateGallery(1));
    },
    
    setActivePhoto(index) {
      AppState.currentPhotoIndex = (index + AppState.currentPhotos.length) % AppState.currentPhotos.length;
      const mainImg = document.getElementById('mainGalleryImg');
      if (mainImg) mainImg.src = AppState.currentPhotos[AppState.currentPhotoIndex];
      document.querySelectorAll('.thumbnail').forEach((thumb, i) => {
        if (i === AppState.currentPhotoIndex) thumb.classList.add('active-thumb');
        else thumb.classList.remove('active-thumb');
      });
    },
    
    navigateGallery(direction) { this.setActivePhoto(AppState.currentPhotoIndex + direction); },
    
    init() {
      if (this.elements.closeBtn) this.elements.closeBtn.addEventListener('click', () => this.close());
      if (this.elements.contactBtn) this.elements.contactBtn.addEventListener('click', () => this.scrollToContactForm());
      if (this.elements.modal) this.elements.modal.addEventListener('click', (e) => { if (e.target === this.elements.modal) this.close(); });
    }
  };
  
  // ============================================================
  // ADMIN FUNCTIES
  // ============================================================
  function renderAdminVehicles() {
    const grid = document.getElementById('vehiclesAdminGrid');
    if (!grid) return;
    
    const availableVehicles = VEHICLES.filter(v => v.status === 'available');
    adminTotalPages = Math.ceil(availableVehicles.length / CONFIG.adminVehiclesPerPage);
    if (adminCurrentPage > adminTotalPages) adminCurrentPage = adminTotalPages;
    if (adminCurrentPage < 1) adminCurrentPage = 1;
    if (adminTotalPages === 0) adminTotalPages = 1;
    
    const startIndex = (adminCurrentPage - 1) * CONFIG.adminVehiclesPerPage;
    const vehiclesToShow = availableVehicles.slice(startIndex, startIndex + CONFIG.adminVehiclesPerPage);
    
    grid.innerHTML = '';
    vehiclesToShow.forEach(vehicle => {
      const isChecked = selectedVehicleIds.has(vehicle.id);
      const whatsappLink = `https://wa.me/?text=${generateWhatsAppText(vehicle)}`;
      
      const card = document.createElement('div');
      card.className = 'vehicle-admin-card';
      card.innerHTML = `
        <input type="checkbox" class="vehicle-select-checkbox" data-id="${vehicle.id}" ${isChecked ? 'checked' : ''}>
        <div><strong>${vehicle.name}</strong> (${vehicle.year})<div style="color:#0046FF; font-weight:700;">${vehicle.price}</div><div style="font-size:0.75rem;">${Utils.formatKm(vehicle.km)} · ${vehicle.fuel}</div></div>
        <div class="card-actions">
          <button class="btn-sm btn-edit" data-id="${vehicle.id}">✏️ Bewerken</button>
          <button class="btn-sm btn-delete" data-id="${vehicle.id}">🗑️ Verwijderen</button>
          <button class="btn-sm btn-sold" data-id="${vehicle.id}">💰 Markeer Verkocht</button>
          <a href="${whatsappLink}" target="_blank" class="btn-whatsapp">📱 WhatsApp</a>
        </div>
      `;
      grid.appendChild(card);
    });
    
    const pageInfo = document.getElementById('adminPageInfo');
    if (pageInfo) pageInfo.innerText = `Pagina ${adminCurrentPage} van ${adminTotalPages}`;
    const prevBtn = document.getElementById('adminPrevPageBtn');
    const nextBtn = document.getElementById('adminNextPageBtn');
    if (prevBtn) prevBtn.disabled = adminCurrentPage <= 1;
    if (nextBtn) nextBtn.disabled = adminCurrentPage >= adminTotalPages;
    
    document.querySelectorAll('.btn-edit').forEach(btn => btn.addEventListener('click', (e) => alert('Bewerk functionaliteit - Uitbreidbaar')));
    document.querySelectorAll('.btn-delete').forEach(btn => btn.addEventListener('click', (e) => { 
      if(confirm('Verwijderen?')) { 
        VEHICLES = VEHICLES.filter(v => v.id != btn.dataset.id); 
        selectedVehicleIds.delete(parseInt(btn.dataset.id));
        renderAdminVehicles(); 
        SideSlide.resetPagination(); 
        updateDashboard(); 
      } 
    }));
    document.querySelectorAll('.btn-sold').forEach(btn => btn.addEventListener('click', (e) => { 
      activeSoldVehicle = VEHICLES.find(v => v.id == btn.dataset.id); 
      if(activeSoldVehicle) document.getElementById('soldModal').classList.add('active'); 
    }));
    
    document.querySelectorAll('.vehicle-select-checkbox').forEach(cb => {
      cb.addEventListener('change', (e) => {
        const vehicleId = parseInt(e.target.dataset.id);
        if (e.target.checked) {
          selectedVehicleIds.add(vehicleId);
        } else {
          selectedVehicleIds.delete(vehicleId);
        }
        updateSelectionBar();
      });
    });
    
    updateSelectionBar();
    updateDashboard();
  }
  
  function updateSelectionBar() {
    const selectionBar = document.getElementById('selectionBar');
    const selectedCountSpan = document.getElementById('selectedCount');
    const count = selectedVehicleIds.size;
    
    if (selectionBar) {
      if (count > 0) {
        selectionBar.style.display = 'flex';
        if (selectedCountSpan) selectedCountSpan.innerText = `${count} voertuig${count !== 1 ? 'en' : ''} geselecteerd`;
      } else {
        selectionBar.style.display = 'none';
      }
    }
  }
  
  function sendBulkWhatsApp() {
    if (selectedVehicleIds.size === 0) {
      alert("Selecteer eerst voertuigen om te delen via WhatsApp.");
      return;
    }
    
    const selectedVehicles = VEHICLES.filter(v => selectedVehicleIds.has(v.id) && v.status === 'available');
    if (selectedVehicles.length === 0) return;
    
    let message = `🚗 *Choupette - Geselecteerde voertuigen* 🚗\n\n`;
    message += `📊 *Totaal: ${selectedVehicles.length} voertuigen*\n\n`;
    message += `─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─\n\n`;
    
    selectedVehicles.forEach((v, index) => {
      message += `${index + 1}. *${v.name}* (${v.year})\n`;
      message += `   💰 Prijs: ${v.price}\n`;
      message += `   📍 Km: ${(v.km || 0).toLocaleString()} km\n`;
      message += `   ⛽ ${v.fuel} | 🔧 ${v.transmission}\n`;
      message += `   📋 ${v.technischeFiche || "113-punten mastercheck"}\n`;
      if (v.extraNotitie) message += `   📝 ${v.extraNotitie}\n`;
      message += `   🔗 ${window.location.href}\n\n`;
      message += `─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─\n\n`;
    });
    
    const encodedMessage = encodeURIComponent(message);
    const whatsappLink = `https://wa.me/?text=${encodedMessage}`;
    window.open(whatsappLink, '_blank');
  }
  
  function adminNextPage() {
    if (adminCurrentPage < adminTotalPages) {
      adminCurrentPage++;
      renderAdminVehicles();
    }
  }
  
  function adminPrevPage() {
    if (adminCurrentPage > 1) {
      adminCurrentPage--;
      renderAdminVehicles();
    }
  }
  
  function selectAllVehiclesOnPage() {
    const availableVehicles = VEHICLES.filter(v => v.status === 'available');
    const startIndex = (adminCurrentPage - 1) * CONFIG.adminVehiclesPerPage;
    const vehiclesOnPage = availableVehicles.slice(startIndex, startIndex + CONFIG.adminVehiclesPerPage);
    
    vehiclesOnPage.forEach(v => {
      selectedVehicleIds.add(v.id);
    });
    
    renderAdminVehicles();
  }
  
  function updateDashboard() {
    const available = VEHICLES.filter(v => v.status === 'available').length;
    const sold = VEHICLES.filter(v => v.status === 'sold').length;
    const revenue = SALES_RECORDS.reduce((sum, s) => sum + s.priceNum, 0);
    const totalProfit = SALES_RECORDS.reduce((sum, s) => sum + (s.priceNum - (s.inkoop || 0) - (s.onkosten || 0)), 0);
    document.getElementById('totalVehicles') && (document.getElementById('totalVehicles').innerText = available);
    document.getElementById('totalSold') && (document.getElementById('totalSold').innerText = sold);
    document.getElementById('totalRevenue') && (document.getElementById('totalRevenue').innerText = Utils.formatCurrency(revenue));
    document.getElementById('totalRevenueFinance') && (document.getElementById('totalRevenueFinance').innerText = Utils.formatCurrency(revenue));
    document.getElementById('totalCashFlow') && (document.getElementById('totalCashFlow').innerText = Utils.formatCurrency(revenue));
    document.getElementById('totalProfit') && (document.getElementById('totalProfit').innerText = Utils.formatCurrency(totalProfit));
    renderSalesTable();
  }
  
  function renderSalesTable(filter = 'all') {
    const tbody = document.getElementById('salesTableBody');
    if (!tbody) return;
    let filtered = [...SALES_RECORDS];
    const now = new Date();
    if (filter === 'today') filtered = filtered.filter(s => { const d = new Date(s.date); return d.toDateString() === now.toDateString(); });
    else if (filter === 'week') { const weekAgo = new Date(); weekAgo.setDate(weekAgo.getDate() - 7); filtered = filtered.filter(s => new Date(s.date) >= weekAgo); }
    else if (filter === 'month') { const monthAgo = new Date(); monthAgo.setMonth(monthAgo.getMonth() - 1); filtered = filtered.filter(s => new Date(s.date) >= monthAgo); }
    tbody.innerHTML = '';
    filtered.forEach(s => { const row = tbody.insertRow(); row.insertCell(0).innerText = s.date; row.insertCell(1).innerText = s.vehicle; row.insertCell(2).innerText = Utils.formatCurrency(s.priceNum); row.insertCell(3).innerText = Utils.formatCurrency(s.onkosten || 0); row.insertCell(4).innerText = Utils.formatCurrency((s.priceNum - (s.inkoop || 0) - (s.onkosten || 0))); row.insertCell(5).innerText = s.method; });
  }
  
  function logoutAdmin() {
    AppState.userRole = 'guest';
    document.getElementById('adminPanel').style.display = 'none';
    selectedVehicleIds.clear();
    alert("U bent uitgelogd als admin.");
  }
  
  function showAdminPanel() { 
    document.getElementById('adminPanel').style.display = 'block'; 
    adminCurrentPage = 1;
    selectedVehicleIds.clear();
    renderAdminVehicles(); 
    SideSlide.resetPagination(); 
    updateDashboard(); 
  }
  
  const Admin = {
    enable() { AppState.userRole = 'admin'; showAdminPanel(); alert("Admin modus geactiveerd. Open een voertuigdetail om de financiële tab te zien."); if (AppState.activeVehicle) Modal.render(); },
    checkAccess() { const pwd = prompt("Admin toegangscode:"); if (pwd === CONFIG.adminCode) this.enable(); else if (pwd) alert("Onjuiste code"); },
    init() { document.querySelector('.logo')?.addEventListener('dblclick', () => this.checkAccess()); document.getElementById('adminTriggerFooter')?.addEventListener('click', (e) => { e.preventDefault(); this.checkAccess(); }); }
  };
  
  document.getElementById('logoutBtn')?.addEventListener('click', logoutAdmin);
  
  document.querySelectorAll('.admin-tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.admin-tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.admin-tab-content').forEach(c => c.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById(btn.dataset.tab).classList.add('active');
    });
  });
  
  document.getElementById('adminPrevPageBtn')?.addEventListener('click', adminPrevPage);
  document.getElementById('adminNextPageBtn')?.addEventListener('click', adminNextPage);
  document.getElementById('selectAllVehiclesBtn')?.addEventListener('click', selectAllVehiclesOnPage);
  document.getElementById('bulkWhatsappBtn')?.addEventListener('click', sendBulkWhatsApp);
  document.getElementById('bulkWhatsappBarBtn')?.addEventListener('click', sendBulkWhatsApp);
  
  document.querySelectorAll('.filter-btn').forEach(btn => btn.addEventListener('click', () => { 
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active')); 
    btn.classList.add('active'); 
    renderSalesTable(btn.dataset.filter); 
  }));
  
  document.getElementById('exportCsvBtn')?.addEventListener('click', () => {
    let csv = "Datum,Voertuig,Factuurbedrag,Onkosten,Winst,Betaalmethode\n";
    SALES_RECORDS.forEach(s => { csv += `${s.date},${s.vehicle},${s.priceNum},${s.onkosten || 0},${s.priceNum - (s.inkoop || 0) - (s.onkosten || 0)},${s.method}\n`; });
    const blob = new Blob([csv], { type: 'text/csv' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'choupette_financieel_rapport.csv';
    a.click();
    URL.revokeObjectURL(url);
  });
  
  document.getElementById('addVehicleForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const priceStr = document.getElementById('newPrice').value.replace(/[^0-9]/g, '');
    const newVehicle = { 
      id: nextVehicleId++, name: document.getElementById('newName').value, year: parseInt(document.getElementById('newYear').value), 
      price: '€ ' + priceStr, priceNum: parseInt(priceStr), km: parseInt(document.getElementById('newKm').value) || 0, 
      fuel: document.getElementById('newFuel').value, transmission: document.getElementById('newTransmission').value, hp: 0, 
      inkoop: parseInt(priceStr) * 0.8, onkosten: 2000, verkoop: parseInt(priceStr), 
      hist: document.getElementById('newHist').value || "Geen historie beschikbaar",
      technischeFiche: document.getElementById('newTechnischeFiche').value || "113-punten mastercheck, originele staat, geen schade verleden",
      extraNotitie: document.getElementById('newExtraNotitie').value || "",
      photoCount: uploadedPhotos.length, status: 'available', photos: uploadedPhotos 
    };
    VEHICLES.push(newVehicle);
    renderAdminVehicles();
    SideSlide.resetPagination();
    updateDashboard();
    document.getElementById('addVehicleForm').reset();
    uploadedPhotos = [];
    document.getElementById('photoPreview').innerHTML = '';
  });
  
  const uploadZone = document.getElementById('uploadZone');
  const photoUpload = document.getElementById('photoUpload');
  uploadZone?.addEventListener('click', () => photoUpload.click());
  photoUpload?.addEventListener('change', (e) => { 
    uploadedPhotos = Array.from(e.target.files); 
    const preview = document.getElementById('photoPreview'); 
    preview.innerHTML = ''; 
    uploadedPhotos.forEach((f, i) => { if(i < 15) { const img = document.createElement('img'); img.src = URL.createObjectURL(f); img.style.width = '50px'; img.style.height = '50px'; img.style.objectFit = 'cover'; img.style.borderRadius = '8px'; preview.appendChild(img); } }); 
  });
  
  document.getElementById('soldForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    if(activeSoldVehicle) {
      const soldPrice = parseInt(document.getElementById('soldPrice').value.replace(/[^0-9]/g, '')) || activeSoldVehicle.priceNum;
      SALES_RECORDS.push({ date: document.getElementById('soldDate').value, vehicle: activeSoldVehicle.name, priceNum: soldPrice, inkoop: activeSoldVehicle.inkoop, onkosten: activeSoldVehicle.onkosten, method: document.getElementById('soldMethod').value });
      activeSoldVehicle.status = 'sold';
      renderAdminVehicles();
      SideSlide.resetPagination();
      updateDashboard();
    }
    document.getElementById('soldModal').classList.remove('active');
  });
  document.getElementById('closeSoldModal')?.addEventListener('click', () => document.getElementById('soldModal').classList.remove('active'));
  
  const ContactForm = {
    elements: { form: document.getElementById('contactForm'), feedback: document.getElementById('formFeedback') },
    submit(e) {
      e.preventDefault();
      const name = document.getElementById('name')?.value;
      const email = document.getElementById('email')?.value;
      const message = document.getElementById('message')?.value;
      if (name && email && message) {
        this.elements.feedback.innerHTML = '<span style="color: #10b981;">✓ Bericht verzonden! Wij nemen spoedig contact op.</span>';
        this.elements.form.reset();
        setTimeout(() => { this.elements.feedback.innerHTML = ''; }, 5000);
      } else {
        this.elements.feedback.innerHTML = '<span style="color: #ef4444;">Vul alle verplichte velden in.</span>';
      }
    },
    init() { if (this.elements.form) this.elements.form.addEventListener('submit', (e) => this.submit(e)); }
  };
  
  function initApp() {
    SideSlide.init();
    Modal.init();
    Admin.init();
    ContactForm.init();
    console.log('Choupette Platform v2.0 - Afbeelding toegevoegd in hero');
  }
  initApp();
</script>
</body>
