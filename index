<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Choupette | Master-level Automotive Platform</title>
  <meta name="description" content="Choupette – Keuring, Diagnose, Overname, Import/Export en Takelwagen. Gecertificeerde voertuigen met mastergarantie.">
  
  <!-- FONTS & ICONS -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&family=Playfair+Display:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  
  <style>
    /* ============================================================ */
    /* 1. DESIGN SYSTEM (VARIABLES & RESET)                        */
    /* ============================================================ */
    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    :root {
      --deep-black: #050505;
      --vibrant-blue: #0046ff;
      --pure-white: #ffffff;
      --off-white: #f8f8f8;
      --gray-light: #eaeaea;
      --gray-mid: #888888;
      --shadow-sm: 0 4px 15px rgba(0, 0, 0, 0.03);
      --shadow-md: 0 10px 35px rgba(0, 0, 0, 0.08);
      --shadow-lg: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
      --shadow-float: 0 20px 40px -12px rgba(0, 70, 255, 0.15);
      --font-sans: 'Inter', sans-serif;
      --font-serif: 'Playfair Display', serif;
      --container-max: 1280px;
      --container-padding: 32px;
    }
    
    body {
      font-family: var(--font-sans);
      background: var(--pure-white);
      color: var(--deep-black);
      line-height: 1.5;
      overflow-x: hidden;
    }
    
    h1, h2, h3 { font-family: var(--font-serif); }
    
    .container {
      max-width: var(--container-max);
      margin: 0 auto;
      padding: 0 var(--container-padding);
    }
    
    /* ============================================================ */
    /* 2. NAVIGATION COMPONENT                                     */
    /* ============================================================ */
    .site-header {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: rgba(255, 255, 255, 0.96);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--gray-light);
    }
    
    .navbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 0;
      flex-wrap: wrap;
    }
    
    .logo {
      font-family: var(--font-serif);
      font-size: 1.8rem;
      font-weight: 800;
      text-decoration: none;
      color: var(--deep-black);
    }
    
    .nav-menu {
      display: flex;
      gap: 2rem;
      list-style: none;
      align-items: center;
      flex-wrap: wrap;
    }
    
    .nav-menu > li { position: relative; }
    .nav-menu > li > a {
      text-decoration: none;
      color: var(--deep-black);
      font-weight: 500;
      transition: color 0.2s;
      cursor: pointer;
    }
    .nav-menu > li > a:hover { color: var(--vibrant-blue); }
    
    .dropdown-menu {
      position: absolute;
      top: 2.2rem;
      left: -1rem;
      background: var(--pure-white);
      backdrop-filter: blur(12px);
      border-radius: 20px;
      padding: 0.75rem 0;
      min-width: 200px;
      opacity: 0;
      visibility: hidden;
      transition: all 0.25s ease;
      box-shadow: var(--shadow-md);
      border: 1px solid var(--gray-light);
      z-index: 100;
    }
    .dropdown:hover .dropdown-menu {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }
    .dropdown-menu a {
      display: block;
      padding: 0.6rem 1.5rem;
      text-decoration: none;
      color: var(--deep-black);
      font-weight: 400;
      transition: all 0.2s;
    }
    .dropdown-menu a:hover {
      background: var(--off-white);
      color: var(--vibrant-blue);
    }
    
    .certified-trigger {
      background: var(--vibrant-blue);
      color: white !important;
      padding: 0.5rem 1.3rem;
      border-radius: 40px;
      font-weight: 600 !important;
      transition: all 0.2s;
      cursor: pointer;
    }
    .certified-trigger:hover {
      background: #0038cc;
      transform: scale(0.98);
    }
    
    /* ============================================================ */
    /* 3. HERO SECTION MET AFBEELDING                               */
    /* ============================================================ */
    .hero {
      min-height: 85vh;
      display: flex;
      align-items: center;
      position: relative;
      background-image: url('Gemini_Generated_Image_f8zitff8zitff8zi.png');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    }
    
    /* Desktop: achtergrond gecentreerd met fixed effect */
    @media (min-width: 769px) {
      .hero {
        background-position: center;
        background-attachment: fixed;
      }
    }
    
    /* Mobiel: aangepaste positie */
    @media (max-width: 768px) {
      .hero {
        background-position: 70% center;
        background-attachment: scroll;
      }
    }
    
    /* Extra kleine schermen */
    @media (max-width: 480px) {
      .hero {
        background-position: 75% center;
      }
    }
    
    /* Donkere overlay voor leesbaarheid */
    .hero::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.55);
      z-index: 1;
    }
    
    .hero-content {
      position: relative;
      z-index: 2;
      max-width: 600px;
    }
    
    .hero-content h1 {
      font-size: 4.5rem;
      font-weight: 800;
      line-height: 1.1;
      color: #ffffff;
      text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
    }
    
    .hero-accent {
      color: var(--vibrant-blue);
    }
    
    .hero-content p {
      color: rgba(255, 255, 255, 0.9);
      text-shadow: 1px 1px 2px rgba(0,0,0,0.3);
    }
    
    /* ============================================================ */
    /* 4. GENERAL SECTION STYLES                                   */
    /* ============================================================ */
    .section {
      padding: 5rem 0;
      border-bottom: 1px solid var(--gray-light);
    }
    .section-title {
      font-size: 2.5rem;
      margin-bottom: 1.5rem;
    }
    
    /* ============================================================ */
    /* 5. CONTACT FORM COMPONENT                                   */
    /* ============================================================ */
    .form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      background: var(--off-white);
      padding: 2rem;
      border-radius: 24px;
    }
    .form-group { display: flex; flex-direction: column; }
    .form-group.full-width { grid-column: span 2; }
    .form-group label {
      font-weight: 500;
      margin-bottom: 0.5rem;
      color: var(--deep-black);
    }
    .form-group input,
    .form-group textarea {
      padding: 0.8rem 1rem;
      border: 1px solid var(--gray-light);
      border-radius: 16px;
      font-family: var(--font-sans);
      transition: all 0.2s;
    }
    .form-group input:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: var(--vibrant-blue);
      box-shadow: 0 0 0 3px rgba(0, 70, 255, 0.1);
    }
    .submit-btn {
      background: var(--vibrant-blue);
      color: white;
      border: none;
      padding: 0.8rem 2rem;
      border-radius: 40px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      width: fit-content;
    }
    .submit-btn:hover {
      background: #0038cc;
      transform: translateY(-2px);
    }
    
    /* ============================================================ */
    /* 6. SIDE SLIDE COMPONENT                                     */
    /* ============================================================ */
    .side-slide {
      position: fixed;
      top: 0;
      right: -45%;
      width: 45%;
      height: 100vh;
      background: var(--pure-white);
      box-shadow: -8px 0 30px rgba(0, 0, 0, 0.1);
      z-index: 2000;
      transition: right 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1);
      overflow-y: auto;
      padding: 2rem;
    }
    .side-slide.open { right: 0; }
    
    .slide-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100vh;
      background: rgba(0, 0, 0, 0.5);
      backdrop-filter: blur(6px);
      z-index: 1999;
      opacity: 0;
      visibility: hidden;
      transition: all 0.3s;
    }
    .slide-overlay.active {
      opacity: 1;
      visibility: visible;
    }
    
    .slide-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 2rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid var(--gray-light);
    }
    
    .vehicle-slide-card {
      background: var(--off-white);
      border-radius: 24px;
      margin-bottom: 1.5rem;
      padding: 1rem;
      transition: all 0.2s;
      border: 1px solid var(--gray-light);
    }
    .vehicle-slide-card:hover {
      transform: translateX(-4px);
      box-shadow: var(--shadow-float);
    }
    
    .detail-dropdown-btn {
      background: transparent;
      border: 1px solid var(--vibrant-blue);
      color: var(--vibrant-blue);
      padding: 0.5rem 1rem;
      border-radius: 30px;
      cursor: pointer;
      margin-top: 0.8rem;
      font-weight: 500;
      transition: all 0.2s;
    }
    .detail-dropdown-btn:hover {
      background: var(--vibrant-blue);
      color: white;
    }
    
    /* ============================================================ */
    /* 7. MODAL COMPONENT (GALLERY) - STICKY HEADER                */
    /* ============================================================ */
    .modal {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.8);
      backdrop-filter: blur(8px);
      z-index: 3000;
      justify-content: center;
      align-items: center;
    }
    .modal.active { display: flex; }
    
    .modal-content {
      background: var(--pure-white);
      width: 90%;
      max-width: 1100px;
      max-height: 85vh;
      border-radius: 32px;
      overflow-y: auto;
      position: relative;
      box-shadow: var(--shadow-lg);
    }
    
    /* STICKY MODAL HEADER - blijft bovenaan bij scrollen */
    .modal-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 2rem;
      border-bottom: 1px solid var(--gray-light);
      background: var(--pure-white);
      position: sticky;
      top: 0;
      z-index: 15;
    }
    
    .contact-seller-btn {
      background: var(--vibrant-blue);
      color: white;
      border: none;
      padding: 0.6rem 1.2rem;
      border-radius: 40px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    
    .contact-seller-btn:hover {
      background: #0038cc;
      transform: scale(0.98);
    }
    
    .modal-close {
      font-size: 1.8rem;
      cursor: pointer;
      background: var(--off-white);
      width: 40px;
      height: 40px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s;
    }
    
    .modal-close:hover {
      background: var(--gray-light);
    }
    
    .gallery-container {
      background: var(--deep-black);
      padding: 2rem;
      border-radius: 0;
      position: relative;
    }
    .main-image-wrapper {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .main-image {
      width: 100%;
      height: 400px;
      object-fit: cover;
      border-radius: 20px;
    }
    .gallery-nav {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      background: rgba(0,0,0,0.6);
      color: white;
      border: none;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      cursor: pointer;
      font-size: 1.2rem;
      transition: all 0.2s;
    }
    .gallery-nav:hover { background: var(--vibrant-blue); }
    .gallery-nav.prev { left: 10px; }
    .gallery-nav.next { right: 10px; }
    
    .thumbnail-strip {
      display: flex;
      gap: 0.8rem;
      overflow-x: auto;
      padding: 1rem 0;
      margin-top: 1rem;
    }
    .thumbnail {
      width: 80px;
      height: 60px;
      object-fit: cover;
      border-radius: 12px;
      cursor: pointer;
      opacity: 0.6;
      transition: 0.2s;
    }
    .thumbnail.active-thumb {
      opacity: 1;
      border: 2px solid var(--vibrant-blue);
    }
    
    .car-detail-info { padding: 2rem; }
    
    .admin-finance-card {
      background: var(--off-white);
      border-radius: 24px;
      padding: 1.5rem;
      margin-top: 1.5rem;
      display: none;
      border-left: 4px solid var(--vibrant-blue);
    }
    .admin-finance-card.visible { display: block; }
    
    /* ============================================================ */
    /* 8. FOOTER COMPONENT MET QR CODE                             */
    /* ============================================================ */
    footer {
      background: var(--deep-black);
      color: var(--gray-mid);
      padding: 3rem 0 2rem;
    }
    .footer-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 2rem;
      margin-bottom: 2rem;
    }
    .footer-col h4 {
      color: white;
      margin-bottom: 1rem;
      font-size: 1.1rem;
    }
    .footer-col p, .footer-col a {
      color: var(--gray-mid);
      text-decoration: none;
      line-height: 1.8;
      transition: color 0.2s;
    }
    .footer-col a:hover { color: var(--vibrant-blue); }
    .social-icons {
      display: flex;
      gap: 1rem;
      margin-top: 1rem;
    }
    .social-icons a { font-size: 1.4rem; color: var(--gray-mid); }
    .social-icons a:hover { color: var(--vibrant-blue); }
    
    /* QR Code stijlen */
    .qr-code {
      text-align: center;
      margin-top: 1rem;
    }
    .qr-code img {
      width: 100px;
      height: 100px;
      background: white;
      padding: 8px;
      border-radius: 12px;
      margin-bottom: 0.5rem;
    }
    .qr-code p {
      font-size: 0.7rem;
      color: var(--gray-mid);
    }
    
    .copyright {
      text-align: center;
      padding-top: 2rem;
      border-top: 1px solid #222;
      font-size: 0.8rem;
    }
    
    /* ============================================================ */
    /* 9. ADMIN PANEL STYLES (LIGHT LUXURY)                        */
    /* ============================================================ */
    .admin-panel {
      background: #F8F9FA;
      border-top: 1px solid #EAEAEA;
      display: none;
    }
    
    .admin-menu {
      position: sticky;
      top: 73px;
      z-index: 999;
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid #EAEAEA;
    }
    
    .admin-tabs {
      display: flex;
      gap: 2rem;
      padding: 1rem 0;
      list-style: none;
    }
    
    .admin-tab-btn {
      background: none;
      border: none;
      padding: 0.5rem 0;
      font-size: 0.95rem;
      font-weight: 500;
      color: #4A5568;
      cursor: pointer;
      transition: all 0.2s;
      position: relative;
    }
    
    .admin-tab-btn:hover { color: #0046FF; }
    .admin-tab-btn.active { color: #0046FF; }
    .admin-tab-btn.active::after {
      content: '';
      position: absolute;
      bottom: -1px;
      left: 0;
      width: 100%;
      height: 3px;
      background: #0046FF;
      border-radius: 3px 3px 0 0;
    }
    
    .admin-tab-content {
      display: none;
      padding: 2rem 0;
    }
    .admin-tab-content.active { display: block; }
    
    .admin-card {
      background: #FFFFFF;
      border: 1px solid #EAEAEA;
      border-radius: 20px;
      padding: 1.5rem;
      margin-bottom: 1.5rem;
    }
    
    .admin-card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid #EAEAEA;
    }
    
    .logout-btn {
      background: #EF4444;
      color: white;
      border: none;
      padding: 0.5rem 1rem;
      border-radius: 8px;
      cursor: pointer;
      font-weight: 500;
      transition: all 0.2s;
    }
    .logout-btn:hover {
      background: #DC2626;
    }
    
    .form-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1rem;
      margin-bottom: 1rem;
    }
    
    .upload-zone {
      border: 2px dashed #EAEAEA;
      border-radius: 16px;
      padding: 1.5rem;
      text-align: center;
      cursor: pointer;
      transition: all 0.2s;
      background: #F8F9FA;
    }
    .upload-zone:hover {
      border-color: #0046FF;
      background: rgba(0, 70, 255, 0.02);
    }
    
    .vehicles-admin-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 1rem;
      margin-top: 1.5rem;
    }
    
    .vehicle-admin-card {
      background: #FFFFFF;
      border: 1px solid #EAEAEA;
      border-radius: 16px;
      padding: 1rem;
      position: relative;
    }
    
    .vehicle-select-checkbox {
      position: absolute;
      top: 10px;
      right: 10px;
      width: 20px;
      height: 20px;
      cursor: pointer;
      z-index: 10;
    }
    
    .card-actions {
      display: flex;
      gap: 0.5rem;
      margin-top: 1rem;
      flex-wrap: wrap;
    }
    
    .btn-sm {
      padding: 0.4rem 0.8rem;
      border-radius: 8px;
      font-size: 0.75rem;
      font-weight: 500;
      cursor: pointer;
      border: none;
      transition: all 0.2s;
    }
    .btn-edit { background: #F8F9FA; color: #0046FF; border: 1px solid #EAEAEA; }
    .btn-edit:hover { background: #0046FF; color: white; }
    .btn-delete { background: #F8F9FA; color: #EF4444; border: 1px solid #EAEAEA; }
    .btn-delete:hover { background: #EF4444; color: white; }
    .btn-sold { background: #10B981; color: white; }
    .btn-sold:hover { background: #0b8f5e; }
    .btn-whatsapp {
      background: #25D366;
      color: white;
      text-decoration: none;
      display: inline-block;
      text-align: center;
      padding: 0.4rem 0.8rem;
      border-radius: 8px;
      font-size: 0.75rem;
      font-weight: 500;
      transition: all 0.2s;
    }
    .btn-whatsapp:hover {
      background: #128C7E;
    }
    .btn-bulk-whatsapp {
      background: #075E54;
      color: white;
      border: none;
      padding: 0.5rem 1rem;
      border-radius: 8px;
      cursor: pointer;
      font-weight: 500;
      margin-left: 1rem;
    }
    .btn-bulk-whatsapp:hover {
      background: #054740;
    }
    .select-all-btn {
      background: #0046FF;
      color: white;
      border: none;
      padding: 0.5rem 1rem;
      border-radius: 8px;
      cursor: pointer;
      font-weight: 500;
    }
    
    .admin-pagination-container {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 1rem;
      margin-top: 1.5rem;
      padding-top: 1rem;
      border-top: 1px solid #EAEAEA;
    }
    .admin-pagination-btn {
      background: #FFFFFF;
      border: 1px solid #EAEAEA;
      border-radius: 8px;
      padding: 0.4rem 0.8rem;
      cursor: pointer;
      transition: all 0.2s;
    }
    .admin-pagination-btn:hover:not(:disabled) {
      background: #0046FF;
      color: white;
      border-color: #0046FF;
    }
    .admin-pagination-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }
    .admin-pagination-info {
      font-size: 0.8rem;
      color: #4A5568;
    }
    
    .selection-bar {
      background: #FFFFFF;
      border: 1px solid #EAEAEA;
      border-radius: 12px;
      padding: 0.75rem 1rem;
      margin-bottom: 1rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;
    }
    
    .finance-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      margin-bottom: 2rem;
    }
    .finance-card {
      background: #FFFFFF;
      border: 1px solid #EAEAEA;
      border-radius: 20px;
      padding: 1.5rem;
      text-align: center;
    }
    .finance-card h3 { font-size: 0.9rem; color: #4A5568; margin-bottom: 0.5rem; }
    .finance-amount { font-size: 1.8rem; font-weight: 700; color: #0046FF; }
    
    .report-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 1rem;
    }
    .report-table th, .report-table td {
      padding: 0.75rem;
      text-align: left;
      border-bottom: 1px solid #EAEAEA;
    }
    .report-table th { background: #F8F9FA; font-weight: 600; color: #4A5568; }
    
    .filter-buttons { display: flex; gap: 0.5rem; margin-bottom: 1rem; }
    .filter-btn {
      padding: 0.4rem 1rem;
      border: 1px solid #EAEAEA;
      border-radius: 20px;
      background: #FFFFFF;
      cursor: pointer;
    }
    .filter-btn.active { background: #0046FF; color: white; border-color: #0046FF; }
    
    .export-btn {
      background: #10B981;
      color: white;
      border: none;
      padding: 0.5rem 1rem;
      border-radius: 12px;
      cursor: pointer;
      margin-bottom: 1rem;
      font-weight: 500;
    }
    
    .sold-modal {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.5);
      backdrop-filter: blur(4px);
      z-index: 4000;
      justify-content: center;
      align-items: center;
